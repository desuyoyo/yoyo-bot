# ===== DISCORD BOT CONFIGURATION =====

# Токен бота (Bot → Token на https://discord.com/developers/applications)
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# ID клиента бота (General Information → Application ID)
CLIENT_ID=YOUR_CLIENT_ID_HERE

# ID сервера (правый клик по серверу → Copy Server ID)
GUILD_ID=YOUR_GUILD_ID_HERE

# ===== МОДУЛЬ: ВРЕМЕННЫЕ КОМНАТЫ =====
# ID каналов-генераторов (через запятую, формат: ID:ЛИМИТ)
# Пример: 123456789:2,987654321:5,111222333:0
# Лимит 0 = без лимита
VOICE_GENERATORS=

# ===== МОДУЛЬ: МОДЕРАЦИЯ =====
# ID канала для логов модерации
MOD_LOG_CHANNEL_ID=

# Белый список доменов (через запятую)
LINK_WHITELIST=youtube.com,youtu.be,tenor.com,discord.com,discord.gg,imgur.com

# Лимит сообщений для антиспама
SPAM_MESSAGE_LIMIT=5
SPAM_TIME_WINDOW=5000
SPAM_TIMEOUT_DURATION=60000

# ===== МОДУЛЬ: МУЗЫКА =====
MUSIC_IDLE_TIMEOUT=120000

# ===== МОДУЛЬ: ИНТЕГРАЦИЯ TELEGRAM =====
# Токен бота Telegram (получите у @BotFather)
TELEGRAM_BOT_TOKEN=

# ID текстового канала в Discord, куда будут прилетать посты (например, 1234567890)
DISCORD_NEWS_CHANNEL_ID=

# (Опционально) ID или @username канала в Telegram, откуда берем посты
TELEGRAM_CHANNEL_ID=

# Чтобы воспроизведение работало музыки работало
DP_FORCE_YTDL_MOD="@distube/ytdl-core"